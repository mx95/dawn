{{ 'section-contact-form.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="contact-split-wrapper gradient color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding">
  <div class="contact-split page-width">
    <header class="contact-split__header">
      {%- if section.settings.heading != blank -%}
        <h1 class="contact-split__heading {{ section.settings.heading_size }}">{{ section.settings.heading }}</h1>
      {%- else -%}
        <h1 class="contact-split__heading h1">{{ 'templates.contact.form.title' | t }}</h1>
      {%- endif -%}
      {%- if section.settings.lead != blank -%}
        <p class="contact-split__lead">{{ section.settings.lead }}</p>
      {%- endif -%}
    </header>

    <div class="contact-split__grid">
      <div class="contact-split__info">
        {%- if section.settings.contact_heading != blank -%}
          <h2 class="visually-hidden">{{ section.settings.contact_heading }}</h2>
        {%- endif -%}
        <div class="contact-split__info-block rte">
          {%- if section.settings.email_show -%}
            <h3>{{ section.settings.email_heading }}</h3>
            <p>
              {%- liquid
                if section.settings.email != blank
                  assign contact_email = section.settings.email
                else
                  assign contact_email = shop.email
                endif
              -%}
              <a href="mailto:{{ contact_email }}">{{ contact_email }}</a>
            </p>
          {%- endif -%}
          {%- if section.settings.phone_show and section.settings.phone != blank -%}
            <h3>{{ section.settings.phone_heading }}</h3>
            <p>
              <a href="tel:{{ section.settings.phone | replace: ' ', '' }}">{{ section.settings.phone }}</a>
            </p>
          {%- endif -%}
          {%- if section.settings.address_show -%}
            <h3>{{ section.settings.address_heading }}</h3>
            <div>{{ section.settings.address_text }}</div>
          {%- endif -%}
        </div>
      </div>

      <div class="contact-split__form-wrap">
        {%- liquid
          assign form_class = 'contact-split__form isolate'
          if settings.animations_reveal_on_scroll
            assign form_class = form_class | append: ' scroll-trigger animate--slide-in'
          endif
          assign fid = 'ContactForm-' | append: section.id
        -%}
        {%- form 'contact', id: fid, class: form_class -%}
          {%- if form.posted_successfully? -%}
            <h2 class="form-status form-status-list form__message h4" tabindex="-1" autofocus>
              {{- 'icon-success.svg' | inline_asset_content -}}
              {{ 'templates.contact.form.post_success' | t }}
            </h2>
          {%- elsif form.errors -%}
            <div class="form__message">
              <h2 class="form-status caption-large text-body h5" role="alert" tabindex="-1" autofocus>
                {{- 'icon-error.svg' | inline_asset_content -}}
                {{ 'templates.contact.form.error_heading' | t }}
              </h2>
            </div>
            <ul class="form-status-list caption-large" role="list">
              <li>
                <a href="#{{ fid }}-email" class="link">
                  {{ form.errors.translated_fields.email | capitalize }}
                  {{ form.errors.messages.email }}
                </a>
              </li>
            </ul>
          {%- endif -%}
          <div class="contact__fields">
            <div class="field">
              <input
                class="field__input"
                autocomplete="name"
                type="text"
                id="{{ fid }}-name"
                name="contact[{{ 'templates.contact.form.name' | t }}]"
                value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
                placeholder="{{ 'templates.contact.form.name' | t }}"
              >
              <label class="field__label" for="{{ fid }}-name">{{ 'templates.contact.form.name' | t }}</label>
            </div>
            <div class="field field--with-error">
              <input
                autocomplete="email"
                type="email"
                id="{{ fid }}-email"
                class="field__input"
                name="contact[email]"
                spellcheck="false"
                autocapitalize="off"
                value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
                aria-required="true"
                {% if form.errors contains 'email' %}
                  aria-invalid="true"
                  aria-describedby="{{ fid }}-email-error"
                {% endif %}
                placeholder="{{ 'templates.contact.form.email' | t }}"
              >
              <label class="field__label" for="{{ fid }}-email">
                {{- 'templates.contact.form.email' | t }}
                <span aria-hidden="true">*</span></label
              >
              {%- if form.errors contains 'email' -%}
                <small class="contact__field-error" id="{{ fid }}-email-error">
                  <span class="visually-hidden">{{ 'accessibility.error' | t }}</span>
                  <span class="form__message">
                    <span class="svg-wrapper">
                      {{- 'icon-error.svg' | inline_asset_content -}}
                    </span>
                    {{- form.errors.translated_fields.email | capitalize }}
                    {{ form.errors.messages.email -}}
                  </span>
                </small>
              {%- endif -%}
            </div>
          </div>
          <div class="field">
            <input
              type="tel"
              id="{{ fid }}-phone"
              class="field__input"
              autocomplete="tel"
              name="contact[{{ 'templates.contact.form.phone' | t }}]"
              pattern="[0-9\-]*"
              value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
              placeholder="{{ 'templates.contact.form.phone' | t }}"
            >
            <label class="field__label" for="{{ fid }}-phone">{{ 'templates.contact.form.phone' | t }}</label>
          </div>
          <div class="field">
            <textarea
              rows="6"
              id="{{ fid }}-body"
              class="text-area field__input"
              name="contact[{{ 'templates.contact.form.comment' | t }}]"
              placeholder="{{ 'templates.contact.form.comment' | t }}"
            >
              {{- form.body -}}
            </textarea>
            <label class="form__label field__label" for="{{ fid }}-body">
              {{- 'templates.contact.form.comment' | t -}}
            </label>
          </div>
          <div class="contact__button">
            <button type="submit" class="button button--primary">{{ section.settings.submit_label }}</button>
          </div>
        {%- endform -%}
      </div>
    </div>

    {%- if section.settings.reply_note != blank -%}
      <div class="contact-split__reply-note rte">{{ section.settings.reply_note }}</div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Contact split",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Contact us"
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "Intro text",
      "default": "Questions about an order or a product? Send us a message — we're happy to help."
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h0"
    },
    {
      "type": "header",
      "content": "Contact column"
    },
    {
      "type": "text",
      "id": "contact_heading",
      "label": "Contact column heading (screen readers)",
      "default": "Contact details"
    },
    {
      "type": "checkbox",
      "id": "email_show",
      "label": "Show email",
      "default": true
    },
    {
      "type": "text",
      "id": "email_heading",
      "label": "Email label",
      "default": "Email"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email address",
      "info": "Leave blank to use store email."
    },
    {
      "type": "checkbox",
      "id": "phone_show",
      "label": "Show phone",
      "default": true
    },
    {
      "type": "text",
      "id": "phone_heading",
      "label": "Phone label",
      "default": "Phone"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone number",
      "default": "+357 00 000000"
    },
    {
      "type": "checkbox",
      "id": "address_show",
      "label": "Show address",
      "default": true
    },
    {
      "type": "text",
      "id": "address_heading",
      "label": "Address label",
      "default": "Visit"
    },
    {
      "type": "richtext",
      "id": "address_text",
      "label": "Address",
      "default": "<p>Your showroom or office address<br>Cyprus</p>"
    },
    {
      "type": "header",
      "content": "Form"
    },
    {
      "type": "text",
      "id": "submit_label",
      "label": "Submit button label",
      "default": "Send message"
    },
    {
      "type": "richtext",
      "id": "reply_note",
      "label": "Reply notice",
      "default": "<p><strong>We usually reply within 24 hours.</strong> For order updates, include your order number.</p>"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Contact split"
    }
  ]
}
{% endschema %}
